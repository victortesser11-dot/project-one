# Copie para .env e preencha com os dados do SEU projeto Supabase
# (conta nova, dedicada ao projeto — NÃO a conta conectada ao ambiente).
# Painel Supabase → Project Settings → API.
#
# A chave anon é pública por design; a segurança vem do RLS no banco.

PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-aqui
