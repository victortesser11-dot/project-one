---
import { empresa } from '../data/empresa';
---

<footer class="mt-16 bg-azul-900 text-cinza-100">
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-12 sm:grid-cols-3">
    <div>
      <h3 class="text-lg font-bold text-white">{empresa.nomeCompleto}</h3>
      <p class="mt-2 text-sm text-cinza-200/80">
        Ligando Arroio dos Ratos a Porto Alegre pela BR-290 desde {empresa.desde}.
      </p>
      <p class="mt-3 text-xs text-cinza-200/60">CNPJ {empresa.cnpj}</p>
    </div>

    <div>
      <h4 class="font-semibold text-white">Contato</h4>
      <ul class="mt-2 space-y-1.5 text-sm">
        {empresa.telefones.map((t) => (
          <li>
            <a href={`tel:+55${t.replace(/\D/g, '')}`} class="hover:text-vermelho-300">{t}</a>
          </li>
        ))}
        <li class="pt-1 text-cinza-200/80">{empresa.endereco}</li>
      </ul>
    </div>

    <div>
      <h4 class="font-semibold text-white">Redes</h4>
      <ul class="mt-2 space-y-1.5 text-sm">
        <li><a href={empresa.facebook} target="_blank" rel="noopener" class="hover:text-vermelho-300">Facebook</a></li>
        <li><a href={`https://wa.me/${empresa.whatsapp}`} target="_blank" rel="noopener" class="hover:text-vermelho-300">WhatsApp {empresa.whatsappExibicao}</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-azul-800">
    <p class="mx-auto max-w-6xl px-4 py-4 text-center text-xs text-cinza-200/50">
      © {new Date().getFullYear()} {empresa.nomeCompleto}. Site em desenvolvimento — proposta.
    </p>
  </div>
</footer>
