---
import Base from '../layouts/Base.astro';
import DemoBanner from '../components/DemoBanner.astro';
import NextBus from '../components/NextBus.astro';
import SearchWidget from '../components/SearchWidget.astro';
import QuickTiles from '../components/QuickTiles.astro';
import { empresa, linkWhatsApp } from '../data/empresa';
import { getHorarios, getTarifa } from '../lib/db';

export const prerender = false; // dados ao vivo via ISR

const horarios = await getHorarios();
const tarifa = await getTarifa();
const tarifaFmt = tarifa.valor.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
---

<Base>
  <DemoBanner />

  <!-- HERO RODOVIA -->
  <section class="hero-rodovia text-white">
    <div class="mx-auto grid max-w-6xl items-center gap-8 px-4 py-12 lg:grid-cols-2 lg:py-16">
      <div>
        <p class="inline-flex items-center gap-2 rounded-sm border-l-2 border-vermelho-500 bg-white/5 px-3 py-1 text-xs font-bold uppercase tracking-widest text-vermelho-400">
          Linha metropolitana &middot; BR-290
        </p>
        <h1 class="mt-4 text-4xl font-extrabold leading-[1.05] sm:text-5xl">
          Arroio dos Ratos<br /><span class="text-vermelho-400">para</span> Porto Alegre
        </h1>
        <p class="mt-4 max-w-md text-cinza-200/90">
          Consulte o horário da sua viagem em segundos. Uma empresa de {new Date().getFullYear() - empresa.desde} anos
          de estrada, ligando o interior à capital todos os dias.
        </p>
      </div>

      <div>
        <p class="mb-2 text-sm font-bold uppercase tracking-wide text-vermelho-400">Consulte seu horário</p>
        <SearchWidget />
      </div>
    </div>
    <div class="faixa-pista"></div>
  </section>

  <!-- PRÓXIMA SAÍDA -->
  <section class="border-b border-cinza-200 bg-cinza-100">
    <div class="mx-auto max-w-6xl px-4 py-8">
      <div class="mb-4 flex items-center justify-between">
        <h2 class="text-sm font-bold uppercase tracking-wide text-tinta-suave">Próxima saída agora</h2>
        <a href="/horarios" class="text-sm font-bold text-azul-700 hover:underline">Ver grade completa →</a>
      </div>
      <NextBus horarios={horarios} />
    </div>
  </section>

  <!-- ATALHOS -->
  <section class="mx-auto max-w-6xl px-4 py-10">
    <QuickTiles />
  </section>

  <!-- FAIXA DE NÚMEROS -->
  <section class="bg-azul-700 text-white">
    <div class="mx-auto grid max-w-6xl grid-cols-2 divide-x divide-azul-600 px-4 py-8 sm:grid-cols-4">
      <div class="px-4 text-center">
        <p class="tabular text-3xl font-extrabold text-white">{empresa.desde}</p>
        <p class="text-xs text-cinza-200/80">desde</p>
      </div>
      <div class="px-4 text-center">
        <p class="tabular text-3xl font-extrabold text-white">{new Date().getFullYear() - empresa.desde}</p>
        <p class="text-xs text-cinza-200/80">anos de estrada</p>
      </div>
      <div class="px-4 text-center">
        <p class="tabular text-3xl font-extrabold text-white">~65</p>
        <p class="text-xs text-cinza-200/80">km pela BR-290</p>
      </div>
      <div class="px-4 text-center">
        <p class="text-3xl font-extrabold text-white">L681</p>
        <p class="text-xs text-cinza-200/80">/ L682 · Metroplan</p>
      </div>
    </div>
  </section>

  <!-- TARIFA + INSTITUCIONAL -->
  <section class="mx-auto max-w-6xl px-4 py-10">
    <div class="grid gap-6 lg:grid-cols-[1fr_1.4fr]">
      <div class="flex flex-col justify-between rounded-xl border border-cinza-200 bg-white p-6">
        <div>
          <p class="text-xs font-bold uppercase tracking-wide text-tinta-suave">Tarifa atual</p>
          <p class="tabular mt-1 text-4xl font-extrabold text-azul-700">{tarifaFmt}</p>
          <p class="mt-1 text-xs text-tinta-suave">Pagamento no embarque · sujeita a reajuste Metroplan</p>
        </div>
        <a
          href={linkWhatsApp('Olá! Gostaria de confirmar a tarifa e horários da linha Arroio dos Ratos ⇄ Porto Alegre.')}
          target="_blank" rel="noopener"
          class="mt-4 inline-block rounded-md bg-azul-700 px-4 py-2.5 text-center text-sm font-bold text-white transition hover:bg-azul-600"
        >
          Confirmar no WhatsApp
        </a>
      </div>

      <div class="rounded-xl bg-asfalto-900 p-8 text-cinza-100">
        <h2 class="text-2xl font-extrabold text-white">Mais de meio século ligando o interior à capital</h2>
        <p class="mt-3 max-w-2xl text-cinza-200/90">
          Desde {empresa.desde}, a {empresa.nomeCompleto} percorre a BR-290 entre Arroio dos Ratos e
          Porto Alegre. Transporte de linha e fretamento feitos por quem conhece cada quilômetro do caminho.
        </p>
        <a href="/fretamento" class="btn-cta mt-5 inline-block px-5 py-2.5 text-sm">Conhecer o fretamento</a>
      </div>
    </div>
  </section>
</Base>
